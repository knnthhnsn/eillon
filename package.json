{
  "name": "eillon",
  "private": true,
  "scripts": {
    "dev": "python3 scripts/dev-server.py",
    "start:local": "bash scripts/start-local.sh",
    "verify": "node scripts/verify-out-of-stock.mjs",
    "verify:links": "node scripts/verify-links.mjs",
    "verify:copy": "node scripts/verify-copy.mjs",
    "verify:head": "node scripts/verify-head.mjs",
    "verify:stockists": "node scripts/verify-stockists.mjs",
    "verify:lifecycle": "node scripts/verify-lifecycle-copy.mjs",
    "verify:analytics": "node scripts/verify-analytics-events.mjs",
    "verify:production": "node scripts/verify-production-parity.mjs",
    "verify:production:required": "node scripts/verify-production-parity.mjs --required",
    "build:manifest": "node scripts/generate-build-manifest.mjs",
    "verify:all": "npm run verify && npm run verify:links && npm run verify:copy && npm run verify:head && npm run verify:stockists && npm run verify:lifecycle && npm run verify:analytics",
    "smoke:funnel": "node scripts/smoke-funnel.mjs",
    "lighthouse:budget": "node scripts/check-lighthouse-budget.mjs",
    "ci": "npm run build && npm run verify:all && npm run smoke:funnel && npm run lighthouse:ci",
    "lighthouse:ci": "node scripts/run-lighthouse-ci.mjs",
    "dev:api": "vercel dev",
    "lighthouse": "npx lighthouse http://localhost:8080/ --only-categories=performance --form-factor=mobile --screenEmulation.mobile --throttling.cpuSlowdownMultiplier=4 --output=json --output-path=./lighthouse-report-latest.json --chrome-flags=\"--headless\"",
    "lighthouse:prod": "npx lighthouse https://eillon.maison/ --only-categories=performance --form-factor=mobile --screenEmulation.mobile --throttling.cpuSlowdownMultiplier=4 --output=json --output-path=./lighthouse-report-latest.json --chrome-flags=\"--headless\"",
    "build:css": "npx clean-css-cli -o styles.min.css styles.css",
    "build:home": "npx clean-css-cli -o home.min.css home.css",
    "build:site": "npx clean-css-cli -o site.min.css site.css",
    "build:letters": "npx clean-css-cli -o letters.min.css letters.css",
    "build:wax-seal": "python scripts/build-wax-seal-logo.py",
    "build:js": "npx terser script.js -o script.min.js -c -m",
    "build:vendor": "node scripts/copy-vendor.mjs",
    "build:sitemap": "node scripts/generate-sitemap.mjs",
    "optimize:images": "python scripts/optimize-images.py",
    "build": "npm run build:css && npm run build:home && npm run build:site && npm run build:letters && npm run build:js && npm run build:vendor && npm run build:sitemap && npm run build:manifest",
    "growth:validate-ledger": "node scripts/growth/validate-ledger.mjs",
    "growth:score": "node scripts/growth/score-experiment.mjs",
    "growth:state": "node scripts/growth/check-state.mjs",
    "growth:next": "node scripts/growth/select-next-experiment.mjs",
    "growth:qa": "node scripts/growth/qa.mjs",
    "growth:validate-ai-review": "node scripts/growth/validate-ai-review.mjs",
    "growth:branch": "node scripts/growth/create-experiment-branch-name.mjs",
    "test:visual": "node scripts/capture-screenshots.mjs",
    "test:dispatch-funnel": "node scripts/simulate-dispatch-funnel.mjs",
    "test:production-visual": "node scripts/capture-production-screenshots.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.0",
    "gsap": "^3.13.0",
    "playwright-core": "^1.61.0"
  }
}
